{
  "expo": {
    "name": "SayCart",
    "slug": "saycart",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f4f6f8"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.saycart.app",
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "SayCart uses speech recognition so you can add groceries and prices by voice.",
        "NSMicrophoneUsageDescription": "SayCart uses the microphone to capture your voice for item and price entry.",
        "NSFaceIDUsageDescription": "SayCart uses Face ID to unlock your vault."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#BAC67A"
      },
      "package": "com.saycart.app",
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.VIBRATE"
      ]
    },
    "plugins": [
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow SayCart to use the microphone for voice entry.",
          "speechRecognitionPermission": "Allow SayCart to use speech recognition for voice entry."
        }
      ],
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#5B21B6"
        }
      ],
      "@react-native-community/datetimepicker"
    ]
  }
}
