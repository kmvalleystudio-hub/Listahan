{
  "name": "listahan",
  "version": "1.0.0",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "node scripts/debug-deps-probe.mjs && expo start",
    "preview": "node scripts/debug-deps-probe.mjs && expo start --web --port 8090",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "debug:deps": "node scripts/debug-deps-probe.mjs",
    "build:apk": "eas build -p android --profile preview",
    "eas:env:sync": "node scripts/sync-eas-env-from-dotenv.mjs",
    "build:apk:full": "node scripts/sync-eas-env-from-dotenv.mjs && eas build -p android --profile preview",
    "qr:install": "node scripts/generate-install-qr.mjs",
    "build:aab": "eas build -p android --profile production",
    "icons:brand": "node scripts/render-listahan-icons.cjs"
  },
  "dependencies": {
    "@expo-google-fonts/caveat": "^0.4.2",
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo-google-fonts/lato": "^0.4.1",
    "@expo-google-fonts/merriweather": "^0.4.2",
    "@expo-google-fonts/nunito": "^0.4.2",
    "@expo-google-fonts/open-sans": "^0.4.2",
    "@expo-google-fonts/poppins": "^0.4.1",
    "@expo-google-fonts/roboto": "^0.4.3",
    "@expo/metro-runtime": "~6.1.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-navigation/native": "^7.0.14",
    "@react-navigation/native-stack": "^7.2.0",
    "@supabase/supabase-js": "^2.105.4",
    "buffer": "^6.0.3",
    "expo": "~54.0.34",
    "expo-asset": "~12.0.13",
    "expo-camera": "~17.0.10",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-file-system": "~19.0.22",
    "expo-font": "~14.0.11",
    "expo-image-picker": "~17.0.11",
    "expo-local-authentication": "~17.0.8",
    "expo-notifications": "~0.32.17",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-speech-recognition": "^3.1.3",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
